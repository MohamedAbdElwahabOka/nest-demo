generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PaymentProvider {
  STRIPE
  PAYMOB
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum OtpChannel {
  WHATSAPP
  SMS
}

model User {
  id        String    @id @default(uuid())
  email     String?   @unique
  password  String?
  phone     String?   @unique
  name      String
  role      Role      @default(USER)
  blogs     Blog[]
  payments  Payment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  content   String
  published Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blogs")
}

model Payment {
  id              String          @id @default(uuid())
  amount          Int             // Amount in cents (e.g., 10000 = 100 EGP or $100)
  currency        String          @default("usd")
  status          PaymentStatus   @default(PENDING)
  provider        PaymentProvider // STRIPE or PAYMOB
  providerOrderId String?         // Stripe session ID or PayMob order ID
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("payments")
}

model OtpVerification {
  id        String     @id @default(uuid())
  phone     String
  name      String
  code      String     // 6-digit OTP code
  channel   OtpChannel // WHATSAPP or SMS
  expiresAt DateTime   // now() + 5 minutes
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now())

  @@index([phone, code]) // Fast lookup during verification
  @@map("otp_verifications")
}
